# =============================================================
# .gitignore — Advisor Bones
# Shiftwork Solutions LLC
# Created: 2026-05-11
# =============================================================

# ── Python ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/

# ── Virtual environments ───────────────────────────────────────
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# ── Environment / secrets ─────────────────────────────────────
# Never commit API keys or connection strings
.env
.env.*
*.env
secrets.py
local_config.py

# ── Local ingestion docs ───────────────────────────────────────
# Keep source documents out of the repo — ingest them, don't commit them
docs/
ingest_docs/
knowledge/docs/
knowledge/source/
*.pdf
*.docx

# ── Static assets (manage separately or add explicitly) ───────
# Uncomment if you don't want images in the repo
# static/

# ── OS files ──────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ── IDE / editor ──────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── Logs ──────────────────────────────────────────────────────
*.log
logs/

# ── Testing / coverage ────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/

# ── Jupyter ───────────────────────────────────────────────────
.ipynb_checkpoints
*.ipynb
